<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Down-sample high-volume access logs. SILO_LOG_SAMPLE_RATE=1 logs all
         (default); N keeps 1 of every N INFO access lines. WARN+ never dropped. -->
    <turboFilter class="com.chrisjenx.silo.server.logging.SamplingTurboFilter">
        <rate>${SILO_LOG_SAMPLE_RATE:-1}</rate>
    </turboFilter>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeContext>false</includeContext>
            <fieldNames>
                <timestamp>ts</timestamp>
                <message>msg</message>
                <logger>logger</logger>
                <thread>thread</thread>
                <levelValue>[ignore]</levelValue>
            </fieldNames>
        </encoder>
    </appender>

    <logger name="io.netty" level="WARN"/>
    <logger name="io.ktor" level="INFO"/>
    <logger name="org.eclipse.jetty" level="WARN"/>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
